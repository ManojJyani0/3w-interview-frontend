# API URL for backend server
VITE_API_URL=http://localhost:5000/api

# Better Auth Configuration (if needed)
VITE_BETTER_AUTH_URL=http://localhost:5000

# Cookie Configuration
# Make sure your backend sets cookies with these properties:
# - httpOnly: true (for security)
# - secure: true (in production with HTTPS)
# - sameSite: 'lax' or 'strict'
# - path: '/'
# - maxAge or expires (for session duration)
